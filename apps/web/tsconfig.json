{
  "extends": "@repo/typescript-config/nextjs.json",
  "compilerOptions": {
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
        "@/*": [
            "./*"
        ],
        "@components/*": [
            "./components/*"
        ],
        "@utils/*": [
            "./utils/*"
        ],
        "@db/*": [
            "./db/*"
        ],
        "@types/*": [
            "./types/*"
        ],
        "@validation/*": [
            "./validation/*"
        ],
        "@providers/*": [
            "./providers/*"
        ],
        "@lib/*": [
            "./lib/*"
        ],
        "@config/*": [
            "./config/*"
        ],
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "next-env.d.ts",
    "next.config.js",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
